---
import ContentLayout from "../../../layouts/ContentLayout.astro";
import { importedArchive, localizeImportedArchivePost } from "../../../lib/linkedinArchive";
import { siteCopy } from "../../../data/site";

const locale = "en";
const copy = siteCopy[locale];

export function getStaticPaths() {
  return importedArchive.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post: rawPost } = Astro.props;
const post = localizeImportedArchivePost(rawPost, locale);
const paragraphs = post.displayBody.split(/\n\s*\n/).map((chunk: string) => chunk.trim()).filter(Boolean);
const originalNote = post.originalLocale === "en" ? copy.archive.fallbackFromEn : copy.archive.fallbackFromRu;
const translationNote = post.originalLocale === "en" ? copy.archive.translatedFromEn : copy.archive.translatedFromRu;
---

<ContentLayout
  title={post.displayTitle}
  description={post.displaySummary}
  locale={locale}
  currentPath={`/writing/archive/${post.slug}`}
  alternatePath={`/ru/writing/archive/${post.slug}`}
  eyebrow={copy.archive.eyebrow}
>
  <div class="detail-meta">
    <span>{new Date(post.date).toLocaleDateString("en-US", { dateStyle: "medium" })}</span>
    <span>{post.usesOriginalText ? (post.originalLocale === "en" ? "Original EN" : "Original RU") : copy.archive.translatedBadge}</span>
    {post.sourceUrl && <span><a href={post.sourceUrl} target="_blank" rel="noreferrer">{copy.archive.sourceLinkLabel}</a></span>}
  </div>
  {(post.usesOriginalText || post.hasHandTranslation) && (
    <div class="archive-note">{post.usesOriginalText ? originalNote : translationNote}</div>
  )}
  {post.coverImage && <p><img src={post.coverImage} alt={post.displayTitle} /></p>}
  <div class="archive-prose">
    {paragraphs.map((paragraph: string) => <p>{paragraph}</p>)}
  </div>
</ContentLayout>
