---
import ContentLayout from "../../../layouts/ContentLayout.astro";
import ArchivePostCard from "../../../components/ArchivePostCard.astro";
import { getLocalizedImportedArchive } from "../../../lib/linkedinArchive";
import { siteCopy } from "../../../data/site";

const locale = "en";
const copy = siteCopy[locale];
const importedArchive = getLocalizedImportedArchive(locale);
---

<ContentLayout
  title={copy.writing.archiveDeckTitle}
  description={copy.writing.archiveDeckIntro}
  locale={locale}
  currentPath="/writing/archive"
  alternatePath="/ru/writing/archive"
>
  <section class="panel-block archive-intro">
    <p class="eyebrow">{copy.writing.archiveDeckEyebrow}</p>
    <h2>{copy.writing.archiveDeckTitle}</h2>
    <p class="lede">{copy.writing.archiveDeckIntro}</p>
    <div class="tag-row">
      <span>{importedArchive.length} {copy.writing.archiveCountLabel}</span>
      <span>{copy.writing.archiveSinceLabel}</span>
    </div>
  </section>

  <div class="card-grid">
    {importedArchive.map((post) => <ArchivePostCard post={post} locale={locale} />)}
  </div>
</ContentLayout>
