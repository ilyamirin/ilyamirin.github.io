---
import { getLocalizedCollection } from "../../lib/i18n";
import ContentLayout from "../../layouts/ContentLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { importedArchive } from "../../lib/linkedinArchive";
import { siteCopy } from "../../data/site";

const locale = "en";
const posts = await getLocalizedCollection("posts", locale);
const copy = siteCopy[locale];
---

<ContentLayout
  title={copy.writing.title}
  description={copy.writing.description}
  locale={locale}
  currentPath="/writing"
  alternatePath="/ru/writing"
>
  <section class="panel-block archive-intro">
    <p class="eyebrow">{copy.writing.archiveEyebrow}</p>
    <h2>{copy.writing.archiveTitle}</h2>
    <p class="lede">{copy.writing.archiveIntro}</p>
    <div class="cta-row">
      <a class="button" href="/writing/archive">{copy.writing.archiveCta}</a>
      <span class="archive-count">{importedArchive.length} {copy.writing.archiveCountLabel}</span>
    </div>
  </section>
  <section class="section section-tight">
    <div class="section-heading">
      <div>
        <p class="eyebrow">{copy.writing.curatedEyebrow}</p>
        <h2>{copy.sectionLabels.writing}</h2>
      </div>
    </div>
  </section>
  <div class="card-grid">
    {posts.map((post) => <PostCard post={post} locale={locale} />)}
  </div>
</ContentLayout>
