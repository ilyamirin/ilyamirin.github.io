---
import ContentLayout from "../../../../layouts/ContentLayout.astro";
import ArchivePostCard from "../../../../components/ArchivePostCard.astro";
import { getFeaturedImportedArchive, getLocalizedArchiveGroups, getLocalizedImportedArchive } from "../../../../lib/linkedinArchive";
import { siteCopy } from "../../../../data/site";

const locale = "ru";
const copy = siteCopy[locale];
const importedArchive = getLocalizedImportedArchive(locale);
const featuredArchive = getFeaturedImportedArchive(locale);
const archiveGroups = getLocalizedArchiveGroups(locale);
---

<ContentLayout
  title={copy.writing.archiveDeckTitle}
  description={copy.writing.archiveDeckIntro}
  locale={locale}
  currentPath="/ru/writing/archive"
  switchPath="/writing/archive"
  alternatePath="/writing/archive"
>
  <section class="panel-block archive-intro">
    <p class="eyebrow">{copy.writing.archiveDeckEyebrow}</p>
    <h2>{copy.writing.archiveDeckTitle}</h2>
    <p class="lede">{copy.writing.archiveDeckIntro}</p>
    <div class="tag-row">
      <span>{importedArchive.length} {copy.writing.archiveCountLabel}</span>
      <span>{copy.writing.archiveSinceLabel}</span>
    </div>
  </section>

  <div class="archive-stack">
    <section class="section section-tight">
      <div class="section-heading">
        <div>
          <p class="eyebrow">{copy.writing.archiveFeaturedEyebrow}</p>
          <h2>{copy.writing.archiveFeaturedTitle}</h2>
        </div>
        <p>{copy.writing.archiveFeaturedIntro}</p>
      </div>
      <div class="card-grid">
        {featuredArchive.map((post) => <ArchivePostCard post={post} locale={locale} />)}
      </div>
    </section>

    <section class="section section-tight">
      <div class="section-heading">
        <div>
          <p class="eyebrow">{copy.writing.archiveTopicsEyebrow}</p>
          <h2>{copy.writing.archiveTopicsTitle}</h2>
        </div>
        <p>{copy.writing.archiveTopicsIntro}</p>
      </div>
      {archiveGroups.map((group) => (
        <section class="archive-topic">
          <div class="section-heading">
            <div>
              <h3>{copy.archive.topicLabels[group.topic]}</h3>
            </div>
          </div>
          <div class="card-grid">
            {group.posts.map((post) => <ArchivePostCard post={post} locale={locale} />)}
          </div>
        </section>
      ))}
    </section>
  </div>
</ContentLayout>
