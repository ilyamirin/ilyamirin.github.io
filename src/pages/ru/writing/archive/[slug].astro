---
import ContentLayout from "../../../../layouts/ContentLayout.astro";
import { importedArchive } from "../../../../lib/linkedinArchive";

export function getStaticPaths() {
  return importedArchive.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const paragraphs = post.body.split(/\n\s*\n/).map((chunk: string) => chunk.trim()).filter(Boolean);
const originalNote =
  post.originalLocale === "ru"
    ? "Оригинальный язык поста: русский. Отдельная английская версия ещё не подготовлена, поэтому в архиве пока сохранён оригинальный текст."
    : "Оригинальный язык поста: английский. Отдельная русская версия ещё не подготовлена, поэтому в архиве пока сохранён оригинальный текст.";
---

<ContentLayout
  title={post.title}
  description={post.summary}
  locale="ru"
  currentPath={`/ru/writing/archive/${post.slug}`}
  switchPath={`/writing/archive/${post.slug}`}
  alternatePath={`/writing/archive/${post.slug}`}
  eyebrow="Импортированный LinkedIn-архив"
>
  <div class="detail-meta">
    <span>{new Date(post.date).toLocaleDateString("ru-RU", { dateStyle: "medium" })}</span>
    <span>{post.originalLocale === "ru" ? "Оригинал RU" : "Оригинал EN"}</span>
    {post.sourceUrl && <span><a href={post.sourceUrl} target="_blank" rel="noreferrer">Открыть в LinkedIn</a></span>}
  </div>
  {post.originalLocale !== "ru" && <div class="archive-note">{originalNote}</div>}
  {post.coverImage && <p><img src={post.coverImage} alt={post.title} /></p>}
  <div class="archive-prose">
    {paragraphs.map((paragraph: string) => <p>{paragraph}</p>)}
  </div>
</ContentLayout>
