---
import { getCollection } from "astro:content";
import ContentLayout from "../../../layouts/ContentLayout.astro";

export async function getStaticPaths() {
  const entries = (await getCollection("projects")).filter((entry) => entry.data.locale === "ru");
  return entries.map((entry) => ({
    params: { slug: entry.data.pathSlug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<ContentLayout
  title={entry.data.title}
  description={entry.data.summary}
  locale="ru"
  currentPath={`/ru/projects/${entry.data.pathSlug}`}
  switchPath={`/projects/${entry.data.pathSlug}`}
  alternatePath={`/projects/${entry.data.pathSlug}`}
  eyebrow={entry.data.role}
>
  <div class="detail-meta">
    <span>{entry.data.proof}</span>
    <span>{entry.data.stack.join(" / ")}</span>
  </div>
  {entry.data.repoUrl && <p><a class="button primary" href={entry.data.repoUrl}>Открыть репозиторий</a></p>}
  <Content />
</ContentLayout>
