---
import type { Locale } from "../lib/i18n";
import type { LocalizedArchivePost } from "../lib/linkedinArchive";
import { withLocalePath } from "../lib/i18n";
import { siteCopy } from "../data/site";

interface Props {
  post: LocalizedArchivePost;
  locale: Locale;
}

const { post, locale } = Astro.props;
const copy = siteCopy[locale];
const href = withLocalePath(locale, `/writing/archive/${post.slug}`);
const date = new Date(post.date);
const originalBadge =
  locale === "ru"
    ? post.originalLocale === "ru"
      ? "Оригинал RU"
      : "Оригинал EN"
    : post.originalLocale === "ru"
      ? "Original RU"
      : "Original EN";
---

<article class="post-card archive-card">
  <p class="eyebrow">{date.toLocaleDateString(locale === "ru" ? "ru-RU" : "en-US", { dateStyle: "medium" })}</p>
  <h3><a href={href}>{post.displayTitle}</a></h3>
  <p>{post.displaySummary}</p>
  <div class="tag-row">
    <span>{post.usesOriginalText ? originalBadge : copy.archive.translatedBadge}</span>
    {post.hasImage && <span>{copy.archive.imageBadge}</span>}
  </div>
</article>
