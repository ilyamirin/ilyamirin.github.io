---
import { defaultLocale, localeLabels, withLocalePath, type Locale } from "../lib/i18n";

type Props = {
  locale: Locale;
  slugPath: string;
};

const { locale, slugPath } = Astro.props;
---

<nav class="locale-switch" aria-label="Language switch">
  {(["en", "ru"] as const).map((entryLocale) => {
    const href = entryLocale === defaultLocale ? slugPath : withLocalePath(entryLocale, slugPath);
    return (
      <a href={href} class:list={[{ active: locale === entryLocale }]} aria-label={localeLabels[entryLocale]}>
        <span class="locale-label-full">{localeLabels[entryLocale]}</span>
        <span class="locale-label-short" aria-hidden="true">{entryLocale.toUpperCase()}</span>
      </a>
    );
  })}
</nav>
