---
import MainLayout from "./MainLayout.astro";
import type { Locale } from "../lib/i18n";

type Props = {
  title: string;
  description: string;
  locale: Locale;
  currentPath: string;
  switchPath?: string;
  alternatePath?: string;
  eyebrow?: string;
};

const { title, description, locale, currentPath, switchPath = currentPath, alternatePath, eyebrow } = Astro.props;
---

<MainLayout
  title={title}
  description={description}
  locale={locale}
  currentPath={currentPath}
  switchPath={switchPath}
  alternatePath={alternatePath}
>
  <section class="content-hero">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    <p class="lede">{description}</p>
  </section>
  <section class="content-shell prose-shell">
    <slot />
  </section>
</MainLayout>
