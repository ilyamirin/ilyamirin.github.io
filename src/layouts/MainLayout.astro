---
import "@fontsource/manrope/400.css";
import "@fontsource/manrope/700.css";
import "@fontsource/space-grotesk/500.css";
import "@fontsource/space-grotesk/700.css";

import BaseHead from "../components/BaseHead.astro";
import LocaleSwitch from "../components/LocaleSwitch.astro";
import { brandConfig, siteCopy } from "../data/site";
import type { Locale } from "../lib/i18n";
import "../styles/global.css";

type Props = {
  title: string;
  description: string;
  locale: Locale;
  currentPath: string;
  switchPath?: string;
  alternatePath?: string;
};

const { title, description, locale, currentPath, switchPath = currentPath, alternatePath } = Astro.props;
const copy = siteCopy[locale];
---

<!doctype html>
<html lang={locale}>
  <head>
    <BaseHead
      title={title}
      description={description}
      locale={locale}
      canonicalPath={currentPath}
      alternatePath={alternatePath}
    />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a href={locale === "en" ? "/" : "/ru"} class="brand">
          <img src={brandConfig.logoMarkPath} alt="" width="34" height="34" class="brand-mark" />
          <span class="brand-name">{copy.siteTitle}</span>
        </a>
        <nav class="site-nav">
          {copy.nav.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </nav>
        <LocaleSwitch locale={locale} slugPath={switchPath} />
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <div class="footer-brand">
          <a href={locale === "en" ? "/" : "/ru"} class="brand">
            <img src={brandConfig.logoMarkPath} alt="" width="34" height="34" class="brand-mark" />
            <span class="brand-name">{copy.siteTitle}</span>
          </a>
          <p>{copy.footer.tagline}</p>
        </div>
        <div class="footer-meta">
          <div class="footer-links">
            {copy.footer.links.map((item) => (
              <a href={item.href} target={item.href.startsWith("http") || item.href.startsWith("mailto:") ? "_blank" : undefined} rel={item.href.startsWith("http") ? "noreferrer" : undefined}>
                {item.label}
              </a>
            ))}
          </div>
          <div class="footer-legal">
            <p>{copy.footer.copyright}</p>
            <p>{copy.footer.codeLicense}</p>
            <p>{copy.footer.contentRights}</p>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
